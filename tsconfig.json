{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "strict": false,
        "noEmit": true,
        "target": "ES2024",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2024", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "isolatedModules": true,
        "types": ["vitest/globals", "node"]
    },
    "include": [
        "ui/**/*.d.ts",
        "ui/**/*.ts",
        "ui/**/*.vue",
        "vite.config.mjs"
    ],
    "exclude": ["dist", "node_modules", "vendor", "ui/tests", "ui/vue/majoor-ui.*"]
}
