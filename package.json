{
  "name": "comfyui-majoor-assetsmanager",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "build:dev": "vite build --mode development",
    "hooks:install": "python scripts/install_local_hooks.py",
    "quality": "python scripts/run_quality_gate.py",
    "quality:changed": "python scripts/run_changed_quality_gate.py",
    "quality:prepush": "python scripts/run_changed_quality_gate.py",
    "quality:py": "python scripts/run_quality_gate.py --python-only",
    "lint:py:fix": "python -m ruff check --fix mjr_am_backend mjr_am_shared tests scripts __init__.py",
    "test:js": "vitest run",
    "test:js:watch": "vitest",
    "test:js:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "lint:js": "eslint js/",
    "lint:js:ox": "oxlint js/ --quiet --disable-unicorn-plugin --ignore-pattern js/vue/majoor-ui.* || node -e \"process.exit(0)\"",
    "lint:dead": "knip --config knip.json || node -e \"process.exit(0)\"",
    "typecheck:js": "tsc -p tsconfig.json --noEmit || node -e \"process.exit(0)\"",
    "lint:js:fix": "eslint js/ --fix",
    "format": "prettier --write \"js/**/*.{js,mjs,vue}\"",
    "format:check": "prettier --check \"js/**/*.{js,mjs,vue}\""
  },
  "devDependencies": {
    "@comfyorg/litegraph": "^0.17.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.14.2",
    "oxlint": "^1.66.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@tanstack/vue-virtual": "^3.13.24",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "three": "0.184.0",
    "vue": "^3.5.34"
  }
}
